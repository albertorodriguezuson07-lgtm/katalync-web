      "id": "a1b2c3d4-1111-4aaa-bbbb-000000000002",
      "name": "Verify Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst { body } = input;\n\nif (!body || !body.token) {\n  return [{ json: { error: 'Token is required', statusCode: 401 } }];\n}\n\ntry {\n  const parts = body.token.split('.');\n  if (parts.length !== 3) {\n    return [{ json: { error: 'Invalid token format', statusCode: 401 } }];\n  }\n  \n  // Base64url decode the payload\n  let payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');\n  while (payload.length % 4) payload += '=';\n  const decoded = JSON.parse(Buffer.from(payload, 'base64').toString('utf8'));\n  \n  if (!decoded.user_id) {\n    return [{ json: { error: 'Invalid token: missing user_id', statusCode: 401 } }];\n  }\n  \n  // Check expiration\n  if (decoded.exp && decoded.exp < Math.floor(Date.now() / 1000)) {\n    return [{ json: { error: 'Token expired', statusCode: 401 } }];\n  }\n  \n  return [{ json: { user_id: decoded.user_id, email: decoded.email || null, valid: true } }];\n} catch (e) {\n  return [{ json: { error: 'Token decode failed: ' + e.message, statusCode: 401 } }];\n}"
      }
    },
    {
      "id": "a1b2c3d4-1111-4aaa-bbbb-000000000003",
      "name": "Check Token Valid",
      "type": "n8n-nodes-base.if",
