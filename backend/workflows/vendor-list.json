    {
      "id": "a1b2c3d4-1111-4aaa-bbbb-000000000008",
      "name": "Merge Vendors with Counts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 160],
      "parameters": {
        "jsCode": "const products = $input.first().json;\nconst productList = Array.isArray(products) ? products : (products.id ? [products] : []);\n\n// Get vendors from previous Code node via $('node_name')\nconst vendorData = $('Get Product Counts').first().json;\nconst vendors = vendorData.vendors || [];\n\n// Count products per vendor\nconst counts = {};\nfor (const p of productList) {\n  if (p.vendor_id) {\n    counts[p.vendor_id] = (counts[p.vendor_id] || 0) + 1;\n  }\n}\n\n// Merge counts into vendors\nconst enrichedVendors = vendors.map(v => ({\n  ...v,\n  product_count_actual: counts[v.id] || 0\n}));\n\nreturn [{ json: { success: true, vendors: enrichedVendors, total: enrichedVendors.length } }];"
      }
