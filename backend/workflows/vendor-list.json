    {
      "id": "a1b2c3d4-1111-4aaa-bbbb-000000000006",
      "name": "Get Product Counts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 160],
      "parameters": {
        "jsCode": "const vendors = $input.first().json;\nconst vendorList = Array.isArray(vendors) ? vendors : [vendors];\n\n// Store vendors for the next HTTP call\n// We'll build vendor IDs to query product counts\nconst vendorIds = vendorList.map(v => v.id).filter(Boolean);\n\nreturn [{ json: { vendors: vendorList, vendorIds } }];"
      }
